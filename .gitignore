# R project files
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# renv
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/
.Rprofile  # managed by renv — commit only if customised

# Data (raw data must not be versioned)
data/raw/
data/processed/
!data/raw/.gitkeep
!data/processed/.gitkeep

# Output (reproducible; regenerated by scripts)
output/figures/
output/tables/
output/maps/
!output/figures/.gitkeep
!output/tables/.gitkeep
!output/maps/.gitkeep

# Rendered documents
manuscript/*.html
manuscript/*.pdf
manuscript/*.docx
docs/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

